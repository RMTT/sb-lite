#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1
PROG=/usr/bin/sblite

start_service() {
	procd_open_instance
	procd_set_param command "$PROG"
	procd_append_param command --state-directory /etc/sblite
	procd_append_param command --listen 0.0.0.0:8180
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
